# ── 运行模式 / Run mode ──────────────────────────────────────────────────────
# local  = 本地 macOS/Windows，自动下载 ChromeDriver，可选显示浏览器窗口
#          Local macOS/Windows, auto-download ChromeDriver, GUI optional
# server = Linux 服务器 / Docker，使用系统 Chromium，强制无头，仅 stdout 日志
#          Linux server / Docker, uses system Chromium, always headless, stdout-only log
RUN_MODE=local

# ── US Visa AIS Portal Credentials ───────────────────────────────────────────
# 美国签证 AIS 门户账号信息
USER_EMAIL=your_email@example.com
USER_PASSWORD=your_password

# ── Consulate / 领事馆 ────────────────────────────────────────────────────────
# Options: Calgary | Halifax | Montreal | Ottawa | Quebec | Toronto | Vancouver
USER_CONSULATE=Vancouver

# ── Date Range Settings (YYYY-MM-DD) / 日期范围设置 ───────────────────────────
EARLIEST_ACCEPTABLE_DATE=2024-05-01
LATEST_ACCEPTABLE_DATE=2024-12-31

# ── Optional Exclusion Ranges / 可选排除区间（最多 9 段）────────────────────────
# EXCLUSION_START_DATE_1=2024-07-01
# EXCLUSION_END_DATE_1=2024-07-31

# ── Feature Toggles / 功能开关 ────────────────────────────────────────────────
SHOW_GUI=false          # true: show browser window (local only) / 显示浏览器（仅本地）
TEST_MODE=false         # true: simulate only, no real booking / 仅模拟，不实际改签
ENABLE_DATE_QUERY=true
ENABLE_EMAIL_NOTIFICATION=true
ENABLE_AUTO_RESCHEDULE=false   # must also set AUTO_RESCHEDULE_CONFIRM=CONFIRM
# AUTO_RESCHEDULE_CONFIRM=CONFIRM

# ── Gmail Notification / 邮件通知（Gmail SMTP）────────────────────────────────
GMAIL_SENDER_NAME=USVISA Notifier
GMAIL_EMAIL=your_sender_email@gmail.com
GMAIL_APPLICATION_PWD=your_gmail_app_password
RECEIVER_NAME=Your Name
RECEIVER_EMAIL=your_recipient_email@example.com

# ── jackdeng-hub Integration (optional) / 与 jackdeng-hub 集成（可选）──────────
# 不填则跳过推送 / Leave blank to skip hub notifications
HUB_URL=https://jackdeng.cc
HUB_TOOL_SLUG=visa-checker
CRON_SECRET=your_cron_secret_here

# ── Advanced Runtime Settings / 高级运行参数（一般无需修改）──────────────────────
# DETACH=true
# NEW_SESSION_AFTER_FAILURES=5
# NEW_SESSION_DELAY=3000
# TIMEOUT=10
# FAIL_RETRY_DELAY=180
# DATE_REQUEST_DELAY=180
# DATE_REQUEST_MAX_RETRY=5
# DATE_REQUEST_MAX_TIME=900
